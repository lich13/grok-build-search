#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path


VERSION = "grok 0.2.93 (f00f96316d4b)"


def path_mode(path: Path) -> str | None:
    try:
        return f"{path.stat().st_mode & 0o777:04o}"
    except FileNotFoundError:
        return None


def log_timing_event(event: str) -> None:
    timing_log = os.environ.get("FAKE_GROK_TIMING_LOG")
    if not timing_log:
        return
    with Path(timing_log).open("a", encoding="utf-8") as log:
        log.write(
            json.dumps(
                {
                    "event": event,
                    "pid": os.getpid(),
                    "time_ns": time.monotonic_ns(),
                }
            )
            + "\n"
        )


def prompt_path_from_args(arguments: list[str]) -> Path | None:
    try:
        prompt_index = arguments.index("--prompt-file") + 1
    except (ValueError, IndexError):
        return None
    return Path(arguments[prompt_index])


def prompt_from_args(arguments: list[str]) -> str:
    prompt_path = prompt_path_from_args(arguments)
    return prompt_path.read_text(encoding="utf-8") if prompt_path else ""


def argument_value(arguments: list[str], name: str) -> str | None:
    try:
        return arguments[arguments.index(name) + 1]
    except (ValueError, IndexError):
        return None


def write_fake_grok_state() -> None:
    if os.environ.get("FAKE_GROK_WRITE_STATE") != "1":
        return
    grok_home = Path(os.environ["GROK_HOME"])
    files = {
        grok_home / "sessions" / "fake-session" / "session.json": "{}\n",
        grok_home / "prompt_history.jsonl": '{"prompt":"test"}\n',
        grok_home / "memory" / "fake-workspace" / "index.json": "{}\n",
        grok_home / "logs" / "fake.log": "fake log\n",
    }
    for path, content in files.items():
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content, encoding="utf-8")

    many_files = int(os.environ.get("FAKE_GROK_MANY_FILES", "0"))
    bulk = grok_home / "bulk"
    bulk.mkdir(exist_ok=True)
    for index in range(many_files):
        (bulk / f"state-{index:05d}").write_text("state\n", encoding="utf-8")


def break_runtime_cleanup() -> None:
    if os.environ.get("FAKE_GROK_BREAK_RUNTIME") != "1":
        return
    runtime = Path(os.environ["GROK_HOME"])
    os.chdir(runtime.parent)
    shutil.rmtree(runtime)
    runtime.write_text("blocks remove_dir_all", encoding="utf-8")


def grok_config_text() -> str | None:
    grok_home = os.environ.get("GROK_HOME")
    if not grok_home:
        return None
    config = Path(grok_home) / "config.toml"
    return config.read_text(encoding="utf-8") if config.is_file() else None


def write_pid_log(path: str, parent: int, child: int) -> None:
    pid_path = Path(path)
    temporary_pid_path = pid_path.with_name(f".{pid_path.name}.tmp")
    temporary_pid_path.write_text(
        json.dumps({"parent": parent, "child": child}), encoding="utf-8"
    )
    temporary_pid_path.replace(pid_path)


def main() -> int:
    arguments = sys.argv[1:]
    if arguments == ["--version"]:
        if os.environ.get("FAKE_GROK_WRITE_STATE_ON_VERSION") == "1":
            write_fake_grok_state()
        break_runtime_cleanup()
        version_log = os.environ.get("FAKE_GROK_VERSION_LOG")
        if version_log:
            grok_home = Path(os.environ["GROK_HOME"])
            Path(version_log).write_text(
                json.dumps(
                    {
                        "grok_home": str(grok_home),
                        "grok_home_mode": path_mode(grok_home),
                        "home": os.environ.get("HOME"),
                    }
                ),
                encoding="utf-8",
            )
        print(os.environ.get("FAKE_GROK_VERSION", VERSION))
        return 0

    mode = os.environ.get("FAKE_GROK_MODE", "search-success")
    prompt_path = prompt_path_from_args(arguments)
    prompt = prompt_from_args(arguments)
    write_fake_grok_state()
    log_path = os.environ.get("FAKE_GROK_LOG")
    if log_path:
        Path(log_path).write_text(
            json.dumps(
                {
                    "args": arguments,
                    "anthropic_api_key": os.environ.get("ANTHROPIC_API_KEY"),
                    "cwd": str(Path.cwd()),
                    "grok_auth_path": os.environ.get("GROK_AUTH_PATH"),
                    "grok_config": grok_config_text(),
                    "grok_home": os.environ.get("GROK_HOME"),
                    "grok_home_mode": (
                        path_mode(Path(os.environ["GROK_HOME"]))
                        if os.environ.get("GROK_HOME")
                        else None
                    ),
                    "grok_home_parent_mode": (
                        path_mode(Path(os.environ["GROK_HOME"]).parent)
                        if os.environ.get("GROK_HOME")
                        else None
                    ),
                    "grok_home_resolved": (
                        str(Path(os.environ["GROK_HOME"]).resolve())
                        if os.environ.get("GROK_HOME")
                        else None
                    ),
                    "grok_storage_mode": os.environ.get("GROK_STORAGE_MODE"),
                    "grok_web_fetch": os.environ.get("GROK_WEB_FETCH"),
                    "home": os.environ.get("HOME"),
                    "mode": mode,
                    "openai_api_key": os.environ.get("OPENAI_API_KEY"),
                    "prompt": prompt,
                    "prompt_mode": (
                        f"{prompt_path.stat().st_mode & 0o777:04o}"
                        if prompt_path
                        else None
                    ),
                    "xai_api_key": os.environ.get("XAI_API_KEY"),
                }
            ),
            encoding="utf-8",
        )

    break_runtime_cleanup()

    if mode == "x-search-serialization":
        if argument_value(arguments, "--tools") != "web_search,web_fetch":
            print(
                "serialization error: unknown variant `x_search`",
                file=sys.stderr,
            )
            return 23
        mode = "search-success"

    if mode == "approval-required":
        if "--always-approve" not in arguments:
            print(
                json.dumps(
                    {
                        "text": "",
                        "stopReason": "Cancelled",
                        "sessionId": "fake-session-id",
                        "requestId": "fake-request-id",
                    }
                )
            )
            return 0
        mode = "search-success"

    if mode == "bad-json":
        print("not-json")
        return 0
    if mode == "exit-failed":
        print("simulated Grok failure", file=sys.stderr)
        if os.environ.get("FAKE_GROK_ERROR_DETAIL") == "1":
            print(f"prompt={prompt_path} token=secret-value", file=sys.stderr)
        return 17
    if mode == "no-sources":
        print(
            json.dumps(
                {
                    "text": "Uncited answer.",
                    "stopReason": "end_turn",
                    "sessionId": "fake-session-id",
                    "requestId": "fake-request-id",
                    "thought": "internal test-only reasoning",
                }
            )
        )
        return 0
    if mode == "sleep":
        log_timing_event("start")
        try:
            time.sleep(float(os.environ.get("FAKE_GROK_SLEEP_SECONDS", "1")))
        finally:
            log_timing_event("end")
        print(
            json.dumps(
                {
                    "text": "Finished sleeping. https://example.com/sleep",
                    "stopReason": "end_turn",
                    "sessionId": "fake-session-id",
                    "requestId": "fake-request-id",
                    "thought": "internal test-only reasoning",
                }
            )
        )
        return 0
    if mode == "spawn-descendant":
        child = subprocess.Popen(
            [
                sys.executable,
                "-c",
                "import time; time.sleep(60)",
            ]
        )
        pid_log = os.environ.get("FAKE_GROK_PID_LOG")
        if pid_log:
            write_pid_log(pid_log, os.getpid(), child.pid)
        time.sleep(60)
        return 0
    if mode == "success-with-descendant":
        child = subprocess.Popen(
            [sys.executable, "-c", "import time; time.sleep(60)"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        pid_log = os.environ.get("FAKE_GROK_PID_LOG")
        if pid_log:
            write_pid_log(pid_log, os.getpid(), child.pid)
        print(
            json.dumps(
                {
                    "text": "Successful parent response. https://example.com/success",
                    "stopReason": "end_turn",
                    "sessionId": "fake-session-id",
                    "requestId": "fake-request-id",
                }
            )
        )
        return 0
    if mode == "escape-process-group":
        pid_log = os.environ.get("FAKE_GROK_PID_LOG")
        if not pid_log:
            print("FAKE_GROK_PID_LOG is required", file=sys.stderr)
            return 2
        child_script = (
            "import json, os, pathlib, sys, time; "
            "os.setsid(); "
            "path = pathlib.Path(sys.argv[1]); "
            "temporary = path.with_name('.' + path.name + '.tmp'); "
            "temporary.write_text("
            "json.dumps({'parent': int(sys.argv[2]), 'child': os.getpid()}), "
            "encoding='utf-8'); "
            "temporary.replace(path); "
            "time.sleep(60)"
        )
        subprocess.Popen(
            [sys.executable, "-c", child_script, pid_log, str(os.getpid())]
        )
        time.sleep(60)
        return 0
    if mode == "stderr-warning":
        print("simulated configuration warning", file=sys.stderr)
        print(
            json.dumps(
                {
                    "text": "Warning did not prevent search. https://example.com/warning",
                    "stopReason": "end_turn",
                    "sessionId": "fake-session-id",
                    "requestId": "fake-request-id",
                    "thought": "internal test-only reasoning",
                }
            )
        )
        return 0
    if mode != "search-success":
        print(f"unsupported fake mode: {mode}", file=sys.stderr)
        return 2

    done_file = os.environ.get("FAKE_GROK_DONE_FILE")
    if done_file:
        Path(done_file).write_text("done\n", encoding="utf-8")

    print(
        json.dumps(
            {
                "text": (
                    "Rust information from the official site.\n\n"
                    "Source: https://www.rust-lang.org/"
                ),
                "stopReason": "end_turn",
                "sessionId": "fake-session-id",
                "requestId": "fake-request-id",
                "thought": "internal test-only reasoning",
            }
        )
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
